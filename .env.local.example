# Local-only credentials for opt-in harness scripts (never commit .env.local)
RUN_E2E_AGENT_EVAL=1
# E2E_PROVIDER=gemini # gemini | openai | openrouter | openai-compatible

# Gemini / Google
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://aiplatform.googleapis.com/v1
# E2E_GEMINI_MODEL=gemini-3.5-flash

# OpenAI
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# E2E_OPENAI_MODEL=

# OpenRouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# E2E_OPENROUTER_MODEL=

# Generic OpenAI-compatible provider
# E2E_COMPATIBLE_API_KEY=
# E2E_COMPATIBLE_BASE_URL=
# E2E_COMPATIBLE_MODEL=

# Optional: operational E2E controls (Phase P)
# E2E_MAX_SCENARIO_RETRIES=1
# E2E_REPORT_PATH=.artifacts/e2e-agent-report.json

# Optional local Expo public environment overrides.
#
# ClawHub browse normally discovers the current public Convex endpoint from
# clawhub.ai. Set this only for local testing against a compatible endpoint or
# when discovery is unavailable in your environment.
# EXPO_PUBLIC_CLAWHUB_CONVEX_URL=https://clawhub-convex.example.invalid
