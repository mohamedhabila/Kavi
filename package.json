{
  "name": "kavi",
  "version": "1.0.0",
  "description": "Kavi is a mobile-first AI assistant for iOS and Android with agentic workflows, on-device models, and remote work tooling.",
  "private": true,
  "license": "MIT",
  "keywords": [
    "react-native",
    "expo",
    "mobile",
    "ai",
    "assistant",
    "llm",
    "mcp",
    "ssh"
  ],
  "main": "index.ts",
  "engines": {
    "node": ">=22 <26",
    "npm": ">=10 <12"
  },
  "scripts": {
    "prestart": "npm run build:editor-assets",
    "start": "expo start",
    "preandroid": "npm run build:editor-assets",
    "android": "expo run:android",
    "preios": "npm run build:editor-assets",
    "ios": "expo run:ios",
    "postinstall": "patch-package && npm run build:editor-assets",
    "build:editor-assets": "node ./scripts/build-editor-assets.js",
    "prebuild:android:release": "npm run build:editor-assets",
    "check:android:release-env": "node ./scripts/build-android-release.js --check",
    "build:android:release": "node ./scripts/build-android-release.js",
    "prebuild:android:aab": "npm run build:editor-assets",
    "build:android:aab": "node ./scripts/build-android-release.js --bundle",
    "prebuild:ios:release-sim": "npm run build:editor-assets",
    "build:ios:release-sim": "mkdir -p ios/build/generated/autolinking ios/build/xcode-release-sim && node --no-warnings --eval \"require('expo/bin/autolinking')\" expo-modules-autolinking react-native-config --json --platform ios > ios/build/generated/autolinking/autolinking.json && node node_modules/react-native/scripts/generate-codegen-artifacts.js --path . --outputPath ios --targetPlatform ios && cd ios && NODE_ENV=production xcodebuild -workspace Kavi.xcworkspace -scheme Kavi -configuration Release -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -derivedDataPath build/xcode-release-sim clean build",
    "web": "expo start --web",
    "check:public-hygiene": "node ./scripts/check-public-repo-state.js",
    "check:public-language": "node ./scripts/check-public-language.js",
    "check:links": "node ./scripts/check-markdown-links.js",
    "check:licenses": "node ./scripts/check-dependency-licenses.js",
    "check:app-metadata": "node ./scripts/check-app-metadata.js",
    "check:i18n": "node ./scripts/check-i18n-consistency.js",
    "check:no-legacy-planning-imports": "node ./scripts/check-no-legacy-planning-imports.js",
    "check:thin-e2e-harness": "node ./scripts/check-thin-e2e-harness.js",
    "check:graph-owned-mutations": "node ./scripts/check-graph-owned-mutations.js",
    "check:dead-exports": "node ./scripts/check-dead-exports.js",
    "check:tool-contracts": "node ./scripts/check-tool-contracts.js",
    "check:maintainability": "node ./scripts/check-maintainability.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --runInBand --coverage --no-cache",
    "test:watch": "jest --watch",
    "test:live:anthropic": "cross-env RUN_LIVE_ANTHROPIC=1 jest --runInBand __tests__/services/LlmService.anthropic.live.test.ts",
    "test:live:native-providers": "cross-env RUN_LIVE_NATIVE_PROVIDER_CHECKS=1 jest --runInBand __tests__/services/LlmService.nativeProviders.live.test.ts",
    "eval:memory": "node ./scripts/memory-eval-harness.js",
    "eval:agent": "node ./scripts/agent-eval-harness.js",
    "eval:recovery": "jest --runInBand __tests__/acceptance/recoveryBenchmark.test.ts",
    "eval:e2e": "node ./scripts/e2e-agent-eval-harness.js",
    "eval:e2e:assess": "node ./scripts/e2e-assessment-collect.js",
    "eval:e2e:providers": "node ./scripts/e2e-provider-matrix.js",
    "eval:on-device": "node ./scripts/on-device-benchmark.js",
    "verify": "npm run check:public-hygiene && npm run check:public-language && npm run check:links && npm run check:licenses && npm run check:app-metadata && npm run check:i18n && npm run check:no-legacy-planning-imports && npm run check:thin-e2e-harness && npm run check:graph-owned-mutations && npm run check:dead-exports && npm run check:tool-contracts && npm run check:maintainability && npm run lint && npm run typecheck && npm test -- --runInBand",
    "verify:strict": "npm run verify && npm run eval:memory && npm run eval:agent",
    "verify:strict:e2e": "node ./scripts/verify-strict-e2e.js"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "dependencies": {
    "@dylankenneally/react-native-ssh-sftp": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/drawer": "^7.12.2",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.17.5",
    "brotli-js": "^1.0.2",
    "croner": "^10.0.1",
    "diff": "^8.0.4",
    "expo": "~55.0.12",
    "expo-asset": "~55.0.13",
    "expo-audio": "~55.0.12",
    "expo-auth-session": "~55.0.12",
    "expo-background-task": "~55.0.9",
    "expo-battery": "~55.0.12",
    "expo-build-properties": "~55.0.12",
    "expo-calendar": "~55.0.13",
    "expo-clipboard": "~55.0.12",
    "expo-contacts": "~55.0.12",
    "expo-crypto": "~55.0.13",
    "expo-device": "~55.0.13",
    "expo-document-picker": "~55.0.12",
    "expo-file-system": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.13",
    "expo-image-picker": "~55.0.17",
    "expo-location": "~55.1.7",
    "expo-mail-composer": "~55.0.13",
    "expo-media-library": "~55.0.13",
    "expo-network": "~55.0.12",
    "expo-notifications": "~55.0.17",
    "expo-secure-store": "~55.0.12",
    "expo-sharing": "~55.0.17",
    "expo-sms": "~55.0.13",
    "expo-speech": "~55.0.12",
    "expo-sqlite": "~55.0.14",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.13",
    "expo-web-browser": "~55.0.13",
    "fflate": "^0.8.3",
    "libphonenumber-js": "^1.13.7",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^2.31.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-marked": "8.1.0",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-view-shot": "4.0.3",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.9.2",
    "shell-quote": "^1.8.4",
    "xstate": "^5.32.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.17",
    "@types/react-test-renderer": "^19.0.0",
    "@types/shell-quote": "^1.7.5",
    "better-sqlite3": "^12.11.1",
    "codemirror": "^6.0.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.14",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.4",
    "react-test-renderer": "19.2.7",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.61.1"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|lucide-react-native|zustand|react-native-marked|marked|github-slugger|html-entities|@jsamr/react-native-li|@jsamr/counter-style|react-native-reanimated-table|react-native-gesture-handler|react-native-screens|react-native-safe-area-context|react-native-sse|react-native-get-random-values|react-native-url-polyfill|react-native-uuid)"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/.private/",
      "<rootDir>/__tests__/fixtures/",
      "<rootDir>/__tests__/helpers/",
      "<rootDir>/__tests__/engine/helpers/",
      "<rootDir>/__tests__/screens/.*\\.testSupport\\.tsx$"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/services/context/types.ts",
      "!src/services/cron/types.ts",
      "!src/services/events/types.ts",
      "!src/services/skills/types.ts",
      "!src/services/voice/voice.ts",
      "!src/engine/tools/native-executor.ts"
    ],
    "coverageDirectory": ".tmp/coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "clover",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70.7,
        "functions": 87.6,
        "lines": 84.3,
        "statements": 83.8
      }
    }
  }
}
